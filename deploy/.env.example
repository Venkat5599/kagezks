# Copy to deploy/.env on the VPS and fill in. NEVER commit the real file.
# Load before starting pm2:  set -a; . deploy/.env; set +a

# --- MCP server / agent engine (root project, run with bun) ---
# Funded Stellar testnet secret that pays tx fees + submits (the session owner).
# On your machine: `stellar keys secret issuer`
VEIL_FEE_SECRET=S...

# Operator account that receives x402 per-call fees (a real testnet G-account).
VEIL_OPERATOR=GC3KDBUQ53VQ377LUDUNSV3RQL3MFRYWYYLXD76TXRVR5O7AEO7Y4CAA

# MCP server port (Caddy proxies /mcp here).
VEIL_MCP_PORT=8402

# Soroban RPC (default is testnet).
VEIL_RPC_URL=https://soroban-testnet.stellar.org

# --- Kage fabric MCP (multi-tenant, DB-driven; kage-fabric pm2 process) ---
# Port Caddy proxies /fabric/mcp here.
KAGE_FABRIC_PORT=8403
# Where the fabric reads published APIs/workflows (the local Next app).
KAGE_ORIGIN=http://localhost:3000
# Optional: inline token->session map (JSON). If unset, sdk/build/agent_keys.json is used.
# KAGE_AGENT_KEYS={"kage_sk_...":{"label":"bot","sessionId":"C...","agentSecret":"S..."}}

# Dashboard -> fabric proxy target (web process). Loopback in prod.
KAGE_FABRIC_URL=http://localhost:8403

# SECURITY: the fabric endpoint is PUBLIC. Leave this UNSET in prod. Set to 1 ONLY on a
# local dev box to let no-token calls settle through the env default session. Setting it
# on a reachable host lets anyone drain the default session cap + relayer XLM.
# KAGE_ALLOW_ANON_SETTLE=1

# Optional: enables the Claude-driven demo agent (agent/demo-agent.ts). Omit for --scripted mode.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Next app (frontend/.env.local, NOT here) ---
# The Neon Postgres URL lives in frontend/.env.local:
#   DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require
